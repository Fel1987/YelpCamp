  <%- layout('layouts/bolierplate') %>
  <h1>All Campgrounds</h1>
    <div><a href="campgrounds/new">Create New campground</a></div>
        <ul>
            <% campgrounds.forEach(campground => { %>
                <li> 
                <a href="/campgrounds/<%= campground.id %>"><%= campground.title %></a>
                </li>
            <% }) %>
        </ul>
